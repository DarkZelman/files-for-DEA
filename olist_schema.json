{
    "dataset_name": "Brazilian E-Commerce Public Dataset by Olist",
    "tables": [
        {
            "table_name": "olist_customers_dataset",
            "columns": [
                {
                    "name": "customer_id",
                    "type": "string",
                    "description": "Key to the orders dataset. Each order has a unique customer_id."
                },
                {
                    "name": "customer_unique_id",
                    "type": "string",
                    "description": "Unique identifier of a customer."
                },
                {
                    "name": "customer_zip_code_prefix",
                    "type": "integer",
                    "description": "First five digits of customer zip code."
                },
                {
                    "name": "customer_city",
                    "type": "string",
                    "description": "Customer city name."
                },
                {
                    "name": "customer_state",
                    "type": "string",
                    "description": "Customer state."
                }
            ],
            "primary_key": [
                "customer_id"
            ],
            "foreign_keys": [
                {
                    "column": "customer_zip_code_prefix",
                    "references": "olist_geolocation_dataset.geolocation_zip_code_prefix"
                }
            ]
        },
        {
            "table_name": "olist_geolocation_dataset",
            "columns": [
                {
                    "name": "geolocation_zip_code_prefix",
                    "type": "integer",
                    "description": "First five digits of zip code."
                },
                {
                    "name": "geolocation_lat",
                    "type": "float",
                    "description": "Latitude."
                },
                {
                    "name": "geolocation_lng",
                    "type": "float",
                    "description": "Longitude."
                },
                {
                    "name": "geolocation_city",
                    "type": "string",
                    "description": "City name."
                },
                {
                    "name": "geolocation_state",
                    "type": "string",
                    "description": "State."
                }
            ]
        },
        {
            "table_name": "olist_order_items_dataset",
            "columns": [
                {
                    "name": "order_id",
                    "type": "string",
                    "description": "Order unique identifier."
                },
                {
                    "name": "order_item_id",
                    "type": "integer",
                    "description": "Sequential number identifying number of items included in the same order."
                },
                {
                    "name": "product_id",
                    "type": "string",
                    "description": "Product unique identifier."
                },
                {
                    "name": "seller_id",
                    "type": "string",
                    "description": "Seller unique identifier."
                },
                {
                    "name": "shipping_limit_date",
                    "type": "datetime",
                    "description": "Seller shipping limit date for handling the order to the logistic partner."
                },
                {
                    "name": "price",
                    "type": "float",
                    "description": "Item price."
                },
                {
                    "name": "freight_value",
                    "type": "float",
                    "description": "Item freight value item (if an order has more than one item the freight value is splitted between items)."
                }
            ],
            "primary_key": [
                "order_id",
                "order_item_id"
            ],
            "foreign_keys": [
                {
                    "column": "order_id",
                    "references": "olist_orders_dataset.order_id"
                },
                {
                    "column": "product_id",
                    "references": "olist_products_dataset.product_id"
                },
                {
                    "column": "seller_id",
                    "references": "olist_sellers_dataset.seller_id"
                }
            ]
        },
        {
            "table_name": "olist_order_payments_dataset",
            "columns": [
                {
                    "name": "order_id",
                    "type": "string",
                    "description": "Order unique identifier."
                },
                {
                    "name": "payment_sequential",
                    "type": "integer",
                    "description": "A customer may pay an order with more than one payment method. If he does so, a sequence will be created to accommodate all payments."
                },
                {
                    "name": "payment_type",
                    "type": "string",
                    "description": "Method of payment chosen by the customer."
                },
                {
                    "name": "payment_installments",
                    "type": "integer",
                    "description": "Number of installments chosen by the customer."
                },
                {
                    "name": "payment_value",
                    "type": "float",
                    "description": "Transaction value."
                }
            ],
            "foreign_keys": [
                {
                    "column": "order_id",
                    "references": "olist_orders_dataset.order_id"
                }
            ]
        },
        {
            "table_name": "olist_order_reviews_dataset",
            "columns": [
                {
                    "name": "review_id",
                    "type": "string",
                    "description": "Review unique identifier."
                },
                {
                    "name": "order_id",
                    "type": "string",
                    "description": "Order unique identifier."
                },
                {
                    "name": "review_score",
                    "type": "integer",
                    "description": "Note ranging from 1 to 5 given by the customer on a satisfaction survey."
                },
                {
                    "name": "review_comment_title",
                    "type": "string",
                    "description": "Comment title from the review left by the customer, in Portuguese."
                },
                {
                    "name": "review_comment_message",
                    "type": "string",
                    "description": "Comment message from the review left by the customer, in Portuguese."
                },
                {
                    "name": "review_creation_date",
                    "type": "datetime",
                    "description": "Shows the date in which the satisfaction survey was sent to the customer."
                },
                {
                    "name": "review_answer_timestamp",
                    "type": "datetime",
                    "description": "Shows the satisfaction survey answer timestamp."
                }
            ],
            "primary_key": [
                "review_id"
            ],
            "foreign_keys": [
                {
                    "column": "order_id",
                    "references": "olist_orders_dataset.order_id"
                }
            ]
        },
        {
            "table_name": "olist_orders_dataset",
            "columns": [
                {
                    "name": "order_id",
                    "type": "string",
                    "description": "Order unique identifier."
                },
                {
                    "name": "customer_id",
                    "type": "string",
                    "description": "Key to the customer dataset. Each order has a unique customer_id."
                },
                {
                    "name": "order_status",
                    "type": "string",
                    "description": "Reference to the order status (delivered, shipped, etc)."
                },
                {
                    "name": "order_purchase_timestamp",
                    "type": "datetime",
                    "description": "Shows the purchase timestamp."
                },
                {
                    "name": "order_approved_at",
                    "type": "datetime",
                    "description": "Shows the payment approval timestamp."
                },
                {
                    "name": "order_delivered_carrier_date",
                    "type": "datetime",
                    "description": "Shows the order posting timestamp. When it was handled to the logistic partner."
                },
                {
                    "name": "order_delivered_customer_date",
                    "type": "datetime",
                    "description": "Shows the actual order delivery date to the customer."
                },
                {
                    "name": "order_estimated_delivery_date",
                    "type": "datetime",
                    "description": "Shows the estimated delivery date that was informed to customer at the purchase moment."
                }
            ],
            "primary_key": [
                "order_id"
            ],
            "foreign_keys": [
                {
                    "column": "customer_id",
                    "references": "olist_customers_dataset.customer_id"
                }
            ]
        },
        {
            "table_name": "olist_products_dataset",
            "columns": [
                {
                    "name": "product_id",
                    "type": "string",
                    "description": "Product unique identifier."
                },
                {
                    "name": "product_category_name",
                    "type": "string",
                    "description": "Root category of product, in Portuguese."
                },
                {
                    "name": "product_name_lenght",
                    "type": "integer",
                    "description": "Number of characters extracted from the product name."
                },
                {
                    "name": "product_description_lenght",
                    "type": "integer",
                    "description": "Number of characters extracted from the product description."
                },
                {
                    "name": "product_photos_qty",
                    "type": "integer",
                    "description": "Number of product published photos."
                },
                {
                    "name": "product_weight_g",
                    "type": "float",
                    "description": "Product weight measured in grams."
                },
                {
                    "name": "product_length_cm",
                    "type": "float",
                    "description": "Product length measured in centimeters."
                },
                {
                    "name": "product_height_cm",
                    "type": "float",
                    "description": "Product height measured in centimeters."
                },
                {
                    "name": "product_width_cm",
                    "type": "float",
                    "description": "Product width measured in centimeters."
                }
            ],
            "primary_key": [
                "product_id"
            ],
            "foreign_keys": [
                {
                    "column": "product_category_name",
                    "references": "product_category_name_translation.product_category_name"
                }
            ]
        },
        {
            "table_name": "olist_sellers_dataset",
            "columns": [
                {
                    "name": "seller_id",
                    "type": "string",
                    "description": "Seller unique identifier."
                },
                {
                    "name": "seller_zip_code_prefix",
                    "type": "integer",
                    "description": "First five digits of seller zip code."
                },
                {
                    "name": "seller_city",
                    "type": "string",
                    "description": "Seller city name."
                },
                {
                    "name": "seller_state",
                    "type": "string",
                    "description": "Seller state."
                }
            ],
            "primary_key": [
                "seller_id"
            ],
            "foreign_keys": [
                {
                    "column": "seller_zip_code_prefix",
                    "references": "olist_geolocation_dataset.geolocation_zip_code_prefix"
                }
            ]
        },
        {
            "table_name": "product_category_name_translation",
            "columns": [
                {
                    "name": "product_category_name",
                    "type": "string",
                    "description": "Category name in Portuguese."
                },
                {
                    "name": "product_category_name_english",
                    "type": "string",
                    "description": "Category name in English."
                }
            ],
            "primary_key": [
                "product_category_name"
            ]
        }
    ]
}
